# ─────────────────────────────────────────────
# Vevira Beauty Frontend – Environment Variables
# Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# ── Site ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vevirabeauty.com
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_API_URL=https://api.vevirabeauty.com

# Orders: processed in Next.js by default. Set SHEET_WEBHOOK_URL (Google Apps Script /exec URL).
SHEET_WEBHOOK_URL=
# Set USE_BACKEND_ORDERS=false only for local dev without the Python API.
# When BACKEND_API_URL is set, orders are proxied to the backend by default.
USE_BACKEND_ORDERS=

# ── Meta Pixel ────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ── TikTok Pixel ─────────────────────────────
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ── Snapchat Pixel ───────────────────────────
NEXT_PUBLIC_SNAP_PIXEL_ID=

# ── Analytics Flags ──────────────────────────
NEXT_PUBLIC_ENABLE_PIXELS=true
NEXT_PUBLIC_ENABLE_ADMIN_EVENTS=true
NEXT_PUBLIC_ENABLE_DEBUG_ANALYTICS=false

# ── Ad redirect manager (/redirectvevira) ─────
# Runtime env on Easypanel (NOT build arg only — must be on running container)
REDIRECT_ADMIN_USERNAME=
REDIRECT_ADMIN_PASSWORD=
# Optional: slugs without database/file (survives redeploy)
# AD_REDIRECTS_JSON={"joint-escalier":"/products/joint-pain-oil","joint-dos":"/products/joint-pain-oil","joint-maman":"/products/joint-pain-oil"}
# Optional: custom JSON store path inside the container
# AD_REDIRECTS_FILE=/app/data/ad-redirects.json
