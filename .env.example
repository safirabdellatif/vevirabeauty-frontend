# ─────────────────────────────────────────────
# MySanad Frontend – Environment Variables
# Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# ── Site ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mysanad.shop
# Use the FastAPI backend for persisted orders, fraud checks, admin metrics, and browser events.
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_API_URL=https://api.mysanad.shop

# ── Orders → Google Sheet ─────────────────────
# Apps Script /exec URL — frontend sends each successful order to the sheet.
# (Backend also supports GOOGLE_SHEET_WEBHOOK_URL; use one or the other to avoid duplicates.)
SHEET_WEBHOOK_URL=

# ── Meta Pixel ────────────────────────────────
# Get from Meta Events Manager → Pixel → Settings
NEXT_PUBLIC_META_PIXEL_ID=

# ── TikTok Pixel ─────────────────────────────
# Get from TikTok Ads Manager → Assets → Events → Web Events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ── Snapchat Pixel ───────────────────────────
# Get from Snap Ads Manager → Assets → Snap Pixel
NEXT_PUBLIC_SNAP_PIXEL_ID=

# ── Analytics Flags ──────────────────────────
# Set to false to disable all pixels (e.g. during dev/staging)
NEXT_PUBLIC_ENABLE_PIXELS=true
# Set to false only if you want to stop sending dashboard funnel events to /events.
NEXT_PUBLIC_ENABLE_ADMIN_EVENTS=true
# Set to true to log all pixel events to browser console
NEXT_PUBLIC_ENABLE_DEBUG_ANALYTICS=false
